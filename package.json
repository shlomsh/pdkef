{
  "name": "pdkef",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Free, open-source PDF tools that run 100% locally in your browser - no upload, no signup, no watermark.",
  "license": "MIT",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "typecheck": "astro check",
    "test": "vitest run",
    "test:e2e": "npm run build && playwright test",
    "test:csp": "node scripts/verify-csp.js",
    "test:gesture-golden-rule": "node scripts/check-gesture-golden-rule.js",
    "test:seo": "node scripts/verify-seo.js",
    "test:css": "node scripts/check-editor-global-css.js && node scripts/check-css-bundle.js"
  },
  "dependencies": {
    "@astrojs/preact": "^6.0.0",
    "@cantoo/pdf-lib": "^2.7.1",
    "@floating-ui/dom": "^1.7.6",
    "@floating-ui/react": "^0.27.19",
    "@pdf-lib/fontkit": "^1.1.1",
    "@vercel/analytics": "^2.0.1",
    "astro": "^7.0.3",
    "lucide-preact": "^1.22.0",
    "pdfjs-dist": "^6.1.200",
    "preact": "^10.29.3",
    "signature_pad": "^5.1.3",
    "sortablejs": "^1.15.7"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@playwright/test": "^1.61.1",
    "@preact/preset-vite": "^2.10.5",
    "@tailwindcss/vite": "^4.3.2",
    "@types/sortablejs": "^1.15.8",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "tailwindcss": "^4.3.2",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
