---
// Renders a complete tool page from a single registry entry (see
// src/data/tools.js). The interactive island is passed in via the default slot
// so each page keeps its own explicit `client:load` import (and any per-tool
// props, e.g. unlock's intent). Everything else - SEO head, hero, content
// cards, footer - is driven by the `tool` object, so a page file is just:
//   const tool = toolsBySlug['merge'];
//   <ToolPageLayout tool={tool}><PdfMergeTool client:load /></ToolPageLayout>
import BaseLayout from './BaseLayout.astro';
import SeoSchema from '../components/SeoSchema.astro';
import ToolHero from '../components/ToolHero.astro';
import AppBar from '../components/AppBar.astro';
import ToolAboutCard from '../components/ToolAboutCard.astro';
import ToolFaqCard from '../components/ToolFaqCard.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const { tool } = Astro.props;
---

<BaseLayout title={tool.seoTitle} description={tool.seoDescription}>
  <Fragment slot="head">
    <SeoSchema name={tool.schemaName} description={tool.seoDescription} faq={tool.faq} />
  </Fragment>

  <AppBar toolName={tool.toolName} />

  <div class="flex min-h-[calc(100svh-3.5rem)] flex-col">
    <ToolHero icon={tool.icon} title={tool.h1} subhead={tool.subhead} slug={tool.slug} />

    <main class="!flex !min-h-0 !flex-1 !flex-col !px-4 !pb-4 min-[560px]:!px-6 min-[768px]:!pb-5">
      <section id="app" class="!my-0 !flex !min-h-0 !w-full !flex-1 !items-center !justify-center min-[1024px]:!justify-start min-[1024px]:[&_.merge-tool]:!p-4 min-[1024px]:[&_.dropzone]:!py-6" aria-label={tool.ariaLabel}>
        <slot />
      </section>
    </main>
  </div>

  <ToolAboutCard
    icon={tool.icon}
    heading={tool.aboutHeading}
    lead={tool.aboutLead}
    steps={tool.steps}
    freeNoteLead={tool.freeNoteLead}
    sketch={tool.aboutSketch}
    iconPos={tool.aboutIconPos}
  />

  <ToolFaqCard faq={tool.faq} sketch={tool.faqSketch} iconPos={tool.faqIconPos} />

  <Footer />
</BaseLayout>
