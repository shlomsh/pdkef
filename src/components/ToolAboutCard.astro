---
// Reusable "How it works" + "Free for everyone" content card for tool pages.
// Pairs with ToolFaqCard.astro; both share CardDecor's geometric sketch + icon
// watermark treatment inside their Tailwind-positioned card surface.
import FeatureCard from './FeatureCard.astro';
import CardDecor from './CardDecor.astro';

interface Step {
  title: string;
  text: string;
}

interface Props {
  icon: any;
  tag?: string;
  heading: string;
  lead: string;
  steps: Step[];
  // Tool-specific opening line of the "Free for everyone" note (may contain
  // inline HTML). Keep the modest, on-device, no-us-vs-them voice. The shared
  // open-source paragraph below is appended automatically, so pages never
  // repeat it.
  freeNoteLead?: string;
  sketch?: 'arcs' | 'waves' | 'rings' | 'grid';
  iconPos?: 'tr' | 'tl' | 'br' | 'bl' | 'cr' | 'cl';
}

// Defined once for the whole suite so the open-source message can never drift.
const sharedOpenSource =
  'It\'s open source under the MIT license, so anyone can read the code, <a class="font-medium text-[var(--color-primary)]" href="https://github.com/shlomsh/pdkef" target="_blank" rel="noopener noreferrer">fork it on GitHub</a>, or share it. Simple PDF tools should be free for everyone.';

const defaultLead =
  "PDkef runs entirely in your browser, so there's no server to pay for and no reason to charge you, add a watermark, show ads, or ask you to sign up. Use it as much as you like.";

const {
  icon,
  tag = 'How it works',
  heading,
  lead,
  steps,
  freeNoteLead = defaultLead,
  sketch = 'arcs',
  iconPos = 'tr',
} = Astro.props;
---

<FeatureCard variant="highlight" class="relative isolate overflow-hidden">
  <CardDecor sketch={sketch} icon={icon} iconPos={iconPos} iconSize={280} />
  <div>
    <span class="mb-2 inline-block text-[0.72rem] font-bold uppercase tracking-normal text-[var(--color-primary)]">{tag}</span>
    <h2 class="mb-4 mt-0 text-[1.6rem] font-bold tracking-normal text-[var(--color-text)]">{heading}</h2>
    <p class="mb-6 mt-0 max-w-[68ch] text-[1.05rem] leading-[1.6] tracking-normal text-[var(--color-text)]">{lead}</p>
    <ol class="mb-7 mt-0 flex list-decimal flex-col gap-[0.6rem] pl-5">
      {steps.map((step) => (
        <li class="text-[0.98rem] leading-[1.6] text-[var(--color-muted)]"><strong class="font-semibold text-[var(--color-text)]">{step.title}.</strong> {step.text}</li>
      ))}
    </ol>
    <section class="mt-7 border-t border-[var(--color-border)] pt-7">
      <h2 class="mb-3 mt-0 text-[1.15rem] font-bold tracking-normal text-[var(--color-text)]">Free for everyone</h2>
      <p class="mb-[0.9rem] mt-0 max-w-[64ch] text-base leading-[1.7] text-[var(--color-muted)]" set:html={freeNoteLead} />
      <p class="m-0 max-w-[64ch] text-base leading-[1.7] text-[var(--color-muted)]" set:html={sharedOpenSource} />
    </section>
  </div>
</FeatureCard>
