---
// Per-page structured data. Only emit FAQPage when the page actually renders
// that content visibly - Google treats FAQ JSON-LD that doesn't match
// on-page content as a structured-data violation. Pass `faq` from a page
// only when its visible markup mirrors it.
interface FaqItem {
  question: string;
  answer: string;
}
interface Props {
  name?: string;
  description: string;
  faq?: FaqItem[];
}

const {
  name = 'PDkef',
  description,
  faq,
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();

const author = {
  '@type': 'Person',
  name: 'Shlomi Shemesh',
  url: 'https://github.com/shlomsh',
};

const softwareApp = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name,
  applicationCategory: 'Utility',
  operatingSystem: 'Any (runs in browser)',
  url: pageUrl,
  description,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  author,
  creator: author,
};

const faqSchema = faq && {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(softwareApp)} />
{faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
