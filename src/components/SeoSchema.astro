---
// Per-page structured data. Only emit HowTo / FAQPage when the page actually
// renders that content visibly — Google treats HowTo/FAQ JSON-LD that doesn't
// match on-page content as a structured-data violation. Pass `howTo` / `faq`
// from a page only when its visible markup mirrors them.
interface HowToStep {
  name: string;
  text: string;
}
interface FaqItem {
  question: string;
  answer: string;
}
interface Props {
  name?: string;
  description: string;
  howTo?: { name: string; steps: HowToStep[] };
  faq?: FaqItem[];
}

const {
  name = 'PDkef',
  description,
  howTo,
  faq,
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const pageUrl = new URL(Astro.url.pathname, Astro.site).toString();

const softwareApp = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name,
  applicationCategory: 'Utility',
  operatingSystem: 'Any (runs in browser)',
  url: pageUrl,
  description,
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
};

const howToSchema = howTo && {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: howTo.name,
  step: howTo.steps.map((s) => ({
    '@type': 'HowToStep',
    name: s.name,
    text: s.text,
  })),
};

const faqSchema = faq && {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer },
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(softwareApp)} />
{howToSchema && <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />}
{faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
