---
// Shared tool-page hero: the suite app bar, the icon-left keyword <h1>, a
// value-prop subhead, and the open-source chip row (identical on every tool).
// Keeps the single crawlable <h1> per page; the app-bar breadcrumb is nav.
interface Props {
  icon: any;
  title: string;
  subhead: string;
  slug: string;
}
const { icon: Icon, title, subhead, slug } = Astro.props;

const iconTone = slug === 'sign'
  ? 'bg-[linear-gradient(150deg,var(--color-primary-hover),var(--color-primary))] text-[var(--color-surface)]'
  : slug === 'redact'
    ? 'bg-[linear-gradient(150deg,var(--color-surface),var(--color-success-soft))] text-[var(--color-success)]'
    : 'bg-[linear-gradient(150deg,var(--color-muted-light),var(--color-border-strong))] text-[var(--color-surface)]';
---

<header class="px-6 pb-8 pt-14 min-[1024px]:px-0 min-[1024px]:pb-4 min-[1024px]:pt-2">
  <div class="mb-3 flex items-center justify-center gap-4">
    <div class={`flex h-[clamp(44px,8vw,52px)] w-[clamp(44px,8vw,52px)] shrink-0 items-center justify-center rounded-2xl border-0 shadow-[0_8px_18px_-8px_var(--color-primary-ring),inset_0_1px_0_rgba(255,255,255,0.5)] min-[1024px]:size-14 ${iconTone}`}>
      <Icon class="h-[55%] w-[55%]" size={28} strokeWidth={1.5} />
    </div>
    <h1 class="mb-0 text-left leading-[1.1] tracking-normal min-[1024px]:text-[2.5rem]">{title}</h1>
  </div>
  <p class="mx-auto max-w-[54rem] min-[1024px]:mt-[0.6rem] min-[1024px]:text-[1rem]">{subhead}</p>
  <div class="mt-6 flex flex-wrap justify-center gap-[0.6rem] min-[1024px]:mt-4">
    <a class="inline-flex items-center gap-[0.45rem] rounded-[10px] border-[0.5px] border-[var(--color-border)] bg-[var(--color-surface)] px-[0.8rem] py-[0.45rem] text-[0.8rem] font-semibold text-[var(--color-text)] no-underline transition-[border-color,transform,color] duration-150 ease-[var(--ease-out)] hover:-translate-y-px hover:border-[var(--color-border-strong)] hover:text-[var(--color-text)]" href="https://github.com/shlomsh/pdkef" target="_blank" rel="noopener noreferrer">
      <svg class="shrink-0 text-[var(--color-text)]" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.85 9.73.5.1.68-.22.68-.49 0-.24-.01-.88-.01-1.72-2.79.62-3.38-1.37-3.38-1.37-.46-1.19-1.11-1.5-1.11-1.5-.91-.64.07-.62.07-.62 1 .07 1.53 1.06 1.53 1.06.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.36-2.22-.26-4.56-1.14-4.56-5.07 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.28 2.75 1.05a9.34 9.34 0 0 1 5 0c1.91-1.33 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.94-2.34 4.81-4.57 5.06.36.32.68.94.68 1.9 0 1.37-.01 2.47-.01 2.81 0 .27.18.6.69.49A10.02 10.02 0 0 0 22 12.25C22 6.58 17.52 2 12 2z" />
      </svg>
      Star us on GitHub
      <svg class="shrink-0 text-[var(--color-primary)]" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 2l2.9 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14l-5-4.87 7.1-1.01L12 2z" />
      </svg>
    </a>
    <span class="inline-flex items-center gap-[0.45rem] rounded-[10px] border-[0.5px] border-[var(--color-border)] bg-[var(--color-surface)] px-[0.8rem] py-[0.45rem] text-[0.8rem] font-semibold text-[var(--color-muted)]">
      <svg class="shrink-0 text-[var(--color-muted-light)]" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 3v18" /><path d="M7 7l-4 6a4 4 0 0 0 8 0l-4-6z" /><path d="M17 7l-4 6a4 4 0 0 0 8 0l-4-6z" /><path d="M6 21h12" /><path d="M8 5h8" />
      </svg>
      MIT licensed
    </span>
    <span class="inline-flex items-center gap-[0.45rem] rounded-[10px] border-[0.5px] border-[var(--color-border)] bg-[var(--color-surface)] px-[0.8rem] py-[0.45rem] text-[0.8rem] font-semibold text-[var(--color-muted)]">
      <svg class="shrink-0 text-[var(--color-muted-light)]" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 3l7 3v6c0 4.5-3 8-7 9-4-1-7-4.5-7-9V6l7-3z" /><path d="M9 12.5l2 2 4-4.5" />
      </svg>
      Runs in your browser
    </span>
  </div>
</header>
