---
// Shared suite app bar for tool pages. The brand pill is a back-to-home link
// (reveals a back arrow on hover) that signals "part of a suite"; the optional
// breadcrumb is a nav label, NOT the page <h1>. Right side carries a quiet
// "on-device" privacy badge. Pure inline SVG, no script, so it adds no CSP
// surface. Uses a favicon square + wordmark for the brand pill.
interface Props {
  toolName?: string;
  isHome?: boolean;
}
const { toolName, isHome = false } = Astro.props;

const brandClasses = isHome
  ? 'inline-flex items-center gap-[0.45rem] rounded-[var(--radius-pill)] border-[0.5px] border-[var(--color-border)] bg-[var(--color-surface)] py-[0.3rem] pr-3 pl-[0.4rem] text-[var(--color-text)] no-underline'
  : 'group inline-flex items-center gap-[0.45rem] rounded-[var(--radius-pill)] border-[0.5px] border-[var(--color-border)] bg-[var(--color-surface)] py-[0.3rem] pr-3 pl-[0.4rem] text-[var(--color-text)] no-underline transition-[border-color,transform] duration-150 ease-[var(--ease-out)] hover:-translate-x-px hover:border-[var(--color-border-strong)]';
---

<div class="sticky top-0 z-20 border-b-[0.5px] border-[var(--color-border)] bg-[color-mix(in_srgb,var(--color-surface)_86%,transparent)] backdrop-blur-[10px] backdrop-saturate-[1.2]">
  <div class="mx-auto flex h-14 max-w-[1080px] items-center gap-[0.85rem] px-6 max-[560px]:gap-[0.55rem] max-[560px]:px-4">
    {isHome ? (
      <div class={brandClasses} aria-label="PDkef logo">
        <img src="/favicon.png" width="24" height="24" alt="" aria-hidden="true" class="block shrink-0 rounded-md" />
        <span class="text-[0.95rem] font-bold tracking-normal">PDkef</span>
      </div>
    ) : (
      <a href="/" class={brandClasses} aria-label="PDkef home, all tools">
        <span class="inline-flex w-0 items-center overflow-hidden text-[var(--color-muted-light)] opacity-0 transition-[width,opacity] duration-[180ms] ease-[var(--ease-out)] group-hover:w-4 group-hover:opacity-100" aria-hidden="true">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M19 12H5" /><path d="M12 19l-7-7 7-7" />
          </svg>
        </span>
        <img src="/favicon.png" width="24" height="24" alt="" aria-hidden="true" class="block shrink-0 rounded-md" />
        <span class="text-[0.95rem] font-bold tracking-normal">PDkef</span>
      </a>
    )}

    {toolName && (
      <span class="inline-flex min-w-0 items-center gap-[0.35rem] text-[0.85rem] font-semibold text-[var(--color-muted)]">
        <svg class="shrink-0 text-[var(--color-muted-light)]" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M9 18l6-6-6-6" />
        </svg>
        <span class="overflow-hidden text-ellipsis whitespace-nowrap">{toolName}</span>
      </span>
    )}

    <span class="ml-auto inline-flex shrink-0 items-center gap-[0.35rem] rounded-[var(--radius-pill)] bg-[var(--color-success-soft)] px-[0.7rem] py-[0.3rem] text-[0.75rem] font-semibold text-[var(--color-success)] max-[560px]:gap-0 max-[560px]:p-[0.4rem] max-[560px]:text-[0]">
      <svg class="max-[560px]:size-4" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 3l7 3v6c0 4.5-3 8-7 9-4-1-7-4.5-7-9V6l7-3z" />
        <path d="M9 12.5l2 2 4-4.5" />
      </svg>
      On-device
    </span>
  </div>
</div>
