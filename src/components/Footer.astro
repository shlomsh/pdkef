---
interface Props {
  summaryText?: string;
}

const { summaryText } = Astro.props;
---
{Astro.slots.has('default') && (
  <div class="tool-faq-section">
    <div class="tool-faq-content">
      {summaryText && <p class="faq-intro">{summaryText}</p>}
      <slot />
      <slot name="how-it-works-extra" />
    </div>
  </div>
)}

<footer class="site-footer">
  <div class="site-footer-inner">
    <p class="credit-line">
      Built with ❤️ by <a href="https://github.com/shlomsh" target="_blank" rel="noopener noreferrer">Shlomi Shemesh</a>. 
      <span class="footer-links-inline">
        <a href="https://github.com/shlomsh/pdkef" target="_blank" rel="noopener noreferrer">GitHub</a> &bull;
        <a href="/licenses">Licenses</a>
      </span>
    </p>
  </div>
</footer>

