---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const title = 'Page not found - PDkef';
const description = 'The page you are looking for does not exist. Browse our free PDF tools instead.';

const tools = [
  { title: 'Merge PDF', href: '/merge' },
  { title: 'Split PDF', href: '/split' },
  { title: 'Remove Pages', href: '/remove-pages' },
  { title: 'Compress PDF', href: '/compress' },
  { title: 'PDF to Image', href: '/pdf-to-image' },
  { title: 'Sign PDF', href: '/sign' },
  { title: 'Unlock PDF', href: '/unlock' },
];
---

<BaseLayout title={title} description={description} noindex={true}>
  <header class="not-found-header mx-auto max-w-[540px] px-6 pb-10 pt-[4.5rem] text-center">
    <div class="mb-6 inline-flex size-20 items-center justify-center rounded-[var(--radius-lg)] bg-[var(--color-primary-soft)] text-[var(--color-primary)]">
      <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
        <path d="M14 2v6h6" />
        <path d="m9.5 13.5 5 5" />
        <path d="m14.5 13.5-5 5" />
      </svg>
    </div>
    <h1 class="mb-3 mt-0 text-[clamp(2rem,5.2vw,3.25rem)] font-bold leading-[1.08] tracking-normal text-[var(--color-text)]">Page not found</h1>
    <p class="mb-8 mt-0 leading-[1.5] text-[var(--color-muted)]">The page you're looking for doesn't exist, or may have moved. Try one of the tools below.</p>
    <a href="/" class="inline-flex items-center justify-center rounded-[var(--radius-pill)] bg-[var(--color-primary)] px-7 py-3 text-[var(--color-surface)] no-underline shadow-[var(--shadow-sm)] transition-[background-color,transform] duration-200 ease-[var(--ease-out)] hover:-translate-y-0.5 hover:bg-[var(--color-primary-hover)]">Back to home</a>
  </header>

  <main>
    <div class="mx-auto mb-12 grid max-w-[760px] grid-cols-4 gap-[0.85rem] px-6 max-[768px]:grid-cols-2">
      {tools.map((tool) => (
        <a href={tool.href} class="flex items-center justify-center rounded-[var(--radius)] border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-4 text-center text-[0.92rem] font-medium text-[var(--color-text)] no-underline shadow-[var(--shadow-sm)] transition-[transform,box-shadow,border-color,color] duration-200 ease-[var(--ease-out)] hover:-translate-y-[3px] hover:border-[var(--color-primary)] hover:text-[var(--color-primary)] hover:shadow-[var(--shadow-md)]">
          {tool.title}
        </a>
      ))}
    </div>
  </main>

  <Footer />
</BaseLayout>
