---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const title = 'Open Source Licenses - PDkef';
const description =
  'Third-party open source software used to build PDkef, and their license terms.';

const packages = [
  {
    name: 'Astro',
    version: '7.0.3',
    license: 'MIT',
    url: 'https://github.com/withastro/astro',
    copyright: 'Copyright (c) 2021 Fred K. Schott',
  },
  {
    name: '@astrojs/preact',
    version: '6.0.0',
    license: 'MIT',
    url: 'https://github.com/withastro/astro/tree/main/packages/integrations/preact',
    copyright: 'Copyright (c) 2021 Fred K. Schott',
  },
  {
    name: 'Preact',
    version: '10.29.3',
    license: 'MIT',
    url: 'https://github.com/preactjs/preact',
    copyright: 'Copyright (c) 2015-present Jason Miller',
  },
  {
    name: '@cantoo/pdf-lib',
    version: '2.7.1',
    license: 'MIT',
    url: 'https://github.com/cantoo-scribe/pdf-lib',
    copyright: 'Copyright (c) 2019 Andrew Dillon',
  },
  {
    name: 'pdf.js (pdfjs-dist)',
    version: '6.1.200',
    license: 'Apache-2.0',
    url: 'https://github.com/mozilla/pdf.js',
    copyright: 'Copyright (c) Mozilla and individual contributors',
  },
  {
    name: 'SortableJS',
    version: '1.15.7',
    license: 'MIT',
    url: 'https://github.com/SortableJS/Sortable',
    copyright: 'Copyright (c) 2019 All contributors to Sortable',
  },
  {
    name: 'signature_pad',
    version: '5.1.3',
    license: 'MIT',
    url: 'https://github.com/szimek/signature_pad',
    copyright: 'Copyright (c) 2018 Szymon Nowak',
  },
  {
    name: '@vercel/analytics',
    version: '2.0.1',
    license: 'MIT',
    url: 'https://github.com/vercel/analytics',
    copyright: 'Copyright (c) 2026 Vercel, Inc.',
  },
  {
    name: 'Caveat Font',
    version: '1.1',
    license: 'OFL-1.1',
    url: 'https://fonts.google.com/specimen/Caveat',
    copyright: 'Copyright The Caveat Project Authors',
  },
  {
    name: 'Dancing Script Font',
    version: '1.1',
    license: 'OFL-1.1',
    url: 'https://fonts.google.com/specimen/Dancing+Script',
    copyright: 'Copyright The Dancing Script Project Authors',
  },
  {
    name: 'Great Vibes Font',
    version: '1.1',
    license: 'OFL-1.1',
    url: 'https://fonts.google.com/specimen/Great+Vibes',
    copyright: 'Copyright The Great Vibes Project Authors',
  },
  {
    name: 'Gveret Levin Font',
    version: '1.1',
    license: 'OFL-1.1',
    url: 'https://fonts.google.com/specimen/Gveret+Levin',
    copyright: 'Copyright The Gveret Levin Project Authors',
  },
  {
    name: 'Pacifico Font',
    version: '1.1',
    license: 'OFL-1.1',
    url: 'https://fonts.google.com/specimen/Pacifico',
    copyright: 'Copyright The Pacifico Project Authors',
  },
  {
    name: 'Playpen Sans Font',
    version: '1.1',
    license: 'OFL-1.1',
    url: 'https://fonts.google.com/specimen/Playpen+Sans',
    copyright: 'Copyright The Playpen Sans Project Authors',
  },
  {
    name: 'Sacramento Font',
    version: '1.1',
    license: 'OFL-1.1',
    url: 'https://fonts.google.com/specimen/Sacramento',
    copyright: 'Copyright The Sacramento Project Authors',
  },
];
---

<BaseLayout title={title} description={description}>
  <header>
    <h1>Open Source Licenses</h1>
    <p>The open source software that powers PDkef, and their license terms.</p>
  </header>

  <main>
    <section id="licenses" class="mx-auto max-w-[760px] px-4 pb-12 pt-8 text-[var(--color-text)]">
      <p class="leading-[1.6] text-[var(--color-muted)]">
        PDkef is built with the following open source packages. We're grateful to their authors and
        maintainers. Each package's full license text is linked below; the original notices are also
        preserved in our <a href="https://github.com/shlomsh/pdkef" target="_blank" rel="noopener noreferrer">source repository</a>.
      </p>

      <table class="my-6 w-full border-collapse text-[0.9rem]">
        <thead>
          <tr>
            <th class="border-b border-[var(--color-border)] px-3 py-3 text-left font-semibold text-[var(--color-muted)]" scope="col">Package</th>
            <th class="border-b border-[var(--color-border)] px-3 py-3 text-left font-semibold text-[var(--color-muted)]" scope="col">Version</th>
            <th class="border-b border-[var(--color-border)] px-3 py-3 text-left font-semibold text-[var(--color-muted)]" scope="col">License</th>
            <th class="border-b border-[var(--color-border)] px-3 py-3 text-left font-semibold text-[var(--color-muted)]" scope="col">Copyright</th>
          </tr>
        </thead>
        <tbody>
          {packages.map((pkg) => (
            <tr>
              <td class="border-b border-[var(--color-border)] px-3 py-3">
                <a href={pkg.url} target="_blank" rel="noopener noreferrer">{pkg.name}</a>
              </td>
              <td class="border-b border-[var(--color-border)] px-3 py-3">{pkg.version}</td>
              <td class="border-b border-[var(--color-border)] px-3 py-3">{pkg.license}</td>
              <td class="border-b border-[var(--color-border)] px-3 py-3">{pkg.copyright}</td>
            </tr>
          ))}
        </tbody>
      </table>

      <p class="leading-[1.6] text-[var(--color-muted)]">
        Full license texts are also available in this project's
        <a href="https://github.com/shlomsh/pdkef/blob/main/THIRD_PARTY_LICENSES.md" target="_blank" rel="noopener noreferrer">THIRD_PARTY_LICENSES.md</a>.
      </p>
    </section>
  </main>

  <Footer />
</BaseLayout>
