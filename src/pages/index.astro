---
import BaseLayout from '../layouts/BaseLayout.astro';
import SeoSchema from '../components/SeoSchema.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const title = 'PDkef - Free, Open Source PDF Tools. No Sign Up, No Server.';
const description = 'A complete suite of PDF tools that run 100% locally in your browser - on desktop or mobile. Free and open source: no sign up, no paywalls, no limits.';

// FAQ schema mirrors the visible questions rendered in the footer below.
const faq = [
  { question: 'Are the tools really free?', answer: 'Yes, completely and permanently - no paywalls, no premium tier, no limits, and no watermark on your exported PDFs.' },
  { question: 'Do I need to sign up or create an account?', answer: 'No. There is no account, no email, and no trial period. Open a tool and use it immediately.' },
  { question: 'Are my files uploaded to a server?', answer: 'No. The tools run 100% locally in your browser, on desktop or mobile. Your PDF files are never sent over the network - they stay on your device the entire time.' },
  { question: 'Is PDkef open source?', answer: 'Yes. The entire codebase is open source under the MIT license, so you can inspect exactly what runs on your device.' },
];

// Ordered by SEO priority score from the keyword research (search volume x
// winnability x client-side fit) - highest-opportunity tools surface first.
const tools = [
  {
    title: 'Sign PDF',
    description: 'Fill out forms and sign agreements securely on your device.',
    href: '/sign/',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="m21 17-2.156-1.868A2.521 2.521 0 0 0 15.2 15.2L11 19.38A2.437 2.437 0 0 1 9.3 20H4" />
        <path d="M21 10.5c.5-.5.5-1.3 0-1.8l-2.2-2.2c-.5-.5-1.3-.5-1.8 0L9 14.2V17h2.8l8.2-8.2Z" />
      </svg>`
  },
  {
    title: 'Merge PDF',
    description: 'Combine multiple PDFs into a single document in seconds.',
    href: '/merge/',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M4 20c0-4 4-8 8-8V4" />
        <path d="M20 20c0-4-4-8-8-8" />
        <path d="m9 7 3-3 3 3" />
      </svg>`
  },
  {
    title: 'PDF to Image',
    description: 'Convert PDF pages into high-quality JPG or PNG images.',
    href: '/pdf-to-image/',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="3" width="18" height="18" rx="2" />
        <circle cx="9" cy="9" r="2" />
        <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21" />
      </svg>`
  },
  {
    title: 'Image to PDF',
    description: 'Combine JPG or PNG images into a single PDF document.',
    href: '/image-to-pdf/',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="3" width="14" height="14" rx="2" />
        <circle cx="8" cy="8" r="1.6" />
        <path d="m4 14 3.5-3.5a1.5 1.5 0 0 1 2 0L14 15" />
        <path d="M14 7h7v14H7v-3" />
      </svg>`
  },
  {
    title: 'Split PDF',
    description: 'Extract specific pages or separate a PDF into multiple files.',
    href: '/split/',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 20v-8c0-4-4-8-8-8" />
        <path d="M12 12c0-4 4-8 8-8" />
        <path d="M4 8V4h4" />
        <path d="M20 8V4h-4" />
      </svg>`
  },
  {
    title: 'Compress PDF',
    description: 'Reduce the file size of your PDF without losing quality.',
    href: '/compress/',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="4" y="3" width="16" height="18" rx="2" />
        <line x1="12" y1="3" x2="12" y2="21" />
        <rect x="10" y="9" width="4" height="5" rx="1" fill="currentColor" />
        <path d="M12 5h3" />
        <path d="M9 7h3" />
        <path d="M12 15h3" />
        <path d="M9 17h3" />
      </svg>`
  },
  {
    title: 'Protect & Unlock',
    description: 'Add a password to secure your PDF or remove a known password.',
    href: '/unlock/',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="5" y="11" width="14" height="10" rx="2" />
        <path d="M8 11V7a4 4 0 0 1 8 0" />
        <circle cx="12" cy="16" r="1.5" fill="currentColor" stroke="none" />
      </svg>`
  },
  {
    title: 'Remove Pages',
    description: 'Delete unwanted pages from your PDF file easily.',
    href: '/remove-pages/',
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 6h18" />
        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6" />
        <path d="M8 6V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
        <line x1="10" y1="11" x2="10" y2="17" />
        <line x1="14" y1="11" x2="14" y2="17" />
      </svg>`
  }
];
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <SeoSchema name="PDkef" description={description} faq={faq} />
  </Fragment>

  <header class="hub-header">
    <div class="title-row">
      <svg width="42" height="42" viewBox="0 0 24 24" fill="none" aria-hidden="true" class="title-logo">
        <rect width="24" height="24" rx="6" fill="var(--color-primary)"/>
        <path d="M7 5h7l3 3v9.5H7z" fill="#fff"/>
        <path d="M14 5v3h3z" fill="#bcd9fb"/>
        <circle cx="16.5" cy="16.5" r="4" fill="var(--color-primary)" stroke="#fff" stroke-width="1.2"/>
      </svg>
      <h1>PDkef - all the PDF tools you need</h1>
    </div>
    <p>100% open source and free, with no sign up and no paywalls - ever. Every tool runs locally in your browser, on your computer or your phone.</p>
  </header>

  <main>
    <div class="tool-grid">
      {tools.map((tool) => (
        <a href={tool.href} class="tool-card">
          <div class="tool-icon" set:html={tool.icon} />
          <div class="tool-content">
            <h2>{tool.title}</h2>
            <p>{tool.description}</p>
          </div>
        </a>
      ))}
    </div>
  </main>

  <script>
    // PWA installation handling
    let installPrompt = null;
    const installBtn = document.getElementById('install-pwa');

    if (installBtn) {
      window.addEventListener('beforeinstallprompt', (e) => {
        e.preventDefault();
        installPrompt = e;
        installBtn.style.display = 'inline-flex';
      });

      installBtn.addEventListener('click', async () => {
        if (!installPrompt) return;
        installPrompt.prompt();
        const { outcome } = await installPrompt.userChoice;
        if (outcome === 'accepted') {
          installPrompt = null;
          installBtn.style.display = 'none';
        }
      });
    }
  </script>

  <Footer>
    <section id="why-us">
      <h2>Why yet another PDF tool?</h2>
      <p>Most free PDF sites run your file through their own servers - which costs them money, so they claw it back with task limits, watermarks, or a forced signup. PDkef is different: it's 100% open source, runs entirely on your device, and is free to use forever - no sign up, no paywalls.</p>
      <ul>
        <li><strong>Free, forever:</strong> no cost, no paywalls, no premium tier hiding the tools you actually need.</li>
        <li><strong>No sign up:</strong> no account, no email, no trial period - open a tool and use it.</li>
        <li><strong>No server:</strong> every tool runs locally, right in your browser, on a computer or a phone.</li>
        <li><strong>No limits:</strong> no watermarks, no daily caps, no page restrictions.</li>
        <li><strong>Open source:</strong> the entire codebase is public and MIT licensed - inspect exactly what runs on your device.</li>
      </ul>
    </section>

    <section id="faq">
      <h2>Frequently asked questions</h2>
      <h3>Are the tools really free?</h3>
      <p>Yes, completely and permanently - no paywalls, no premium tier, no limits, and no watermark on your exported PDFs.</p>
      <h3>Do I need to sign up or create an account?</h3>
      <p>No. There is no account, no email, and no trial period. Open a tool and use it immediately.</p>
      <h3>Are my files uploaded to a server?</h3>
      <p>No. The tools run 100% locally in your browser, on desktop or mobile. Your PDF files are never sent over the network - they stay on your device the entire time.</p>
      <h3>Is PDkef open source?</h3>
      <p>Yes. The entire codebase is open source under the MIT license, so you can inspect exactly what runs on your device.</p>
    </section>

    <button slot="about-extra" id="install-pwa" class="install-pwa-button" style="display: none; margin-top: 1.5rem;">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
        <polyline points="7 10 12 15 17 10" />
        <line x1="12" y1="15" x2="12" y2="3" />
      </svg>
      Install as local app
    </button>
  </Footer>
</BaseLayout>

<style>
  .hub-header {
    padding: 3.5rem 1.5rem 2rem;
  }
  
  .title-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }
  
  .title-logo {
    flex-shrink: 0;
  }

  .hub-header h1 {
    margin-bottom: 0;
    text-align: left;
  }

  .tool-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-auto-rows: 1fr;
    gap: 1.5rem;
    margin-top: 2.5rem;
    margin-bottom: 2rem;
  }

  .tool-card {
    grid-column: span 3;
  }

  @media (max-width: 1024px) {
    .tool-grid {
      grid-template-columns: repeat(6, 1fr);
    }
    .tool-card {
      grid-column: span 3;
    }
  }

  @media (max-width: 768px) {
    .tool-grid {
      grid-template-columns: 1fr;
      grid-auto-rows: auto;
    }
    .tool-card {
      grid-column: auto;
    }
  }

  .tool-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    box-shadow: var(--shadow-sm);
    transition: transform 0.4s var(--ease-out), box-shadow 0.4s var(--ease-out), border-color 0.4s var(--ease-out);
    position: relative;
    overflow: hidden;
  }

  .tool-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, var(--color-primary-tint) 0%, transparent 70%);
    opacity: 0;
    transition: opacity 0.4s var(--ease-out);
    pointer-events: none;
    z-index: 0;
  }

  .tool-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md), 0 12px 24px -8px var(--color-primary-ring);
    border-color: var(--color-border-strong);
  }

  .tool-card:hover::before {
    opacity: 1;
  }

  .tool-icon, .tool-content {
    position: relative;
    z-index: 1;
  }

  .tool-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: var(--radius);
    background: var(--color-primary-soft);
    color: var(--color-primary);
    margin-bottom: 1.25rem;
    transition: transform 0.2s var(--ease-spring), background-color 0.2s var(--ease-out);
  }

  .tool-card:hover .tool-icon {
    background: var(--color-primary);
    color: white;
    transform: scale(1.05);
  }

  .tool-content h2 {
    font-size: 1.15rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
    color: var(--color-text);
  }

  .tool-content p {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.5;
    color: var(--color-muted);
  }
</style>
