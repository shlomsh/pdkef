---
import BaseLayout from '../layouts/BaseLayout.astro';
import SeoSchema from '../components/SeoSchema.astro';
import Footer from '../components/Footer.astro';
import FeatureCard from '../components/FeatureCard.astro';
import CardDecor from '../components/CardDecor.astro';
import '../styles/global.css';

const title = 'Free PDF Tools - Private, Local, No Sign-Up | PDkef';
const description = 'A free, open-source suite of PDF tools that run entirely in your browser. Merge, sign, split, compress, and convert PDFs with nothing uploaded, no account, and no watermark. Your files never leave your device.';

import { Monitor, Smartphone, Compass, Sparkles, HardDriveDownload, WifiOff, HelpCircle, ShieldCheck, InfinityIcon, Lock, Code2 } from 'lucide-preact';
import { tools } from '../data/tools.js';

// FAQ schema mirrors the visible questions rendered in the footer below.
const faq = [
  { question: 'Are the tools really free?', answer: 'Yes, completely and permanently - no paywalls, no premium tier, no limits, and no watermark on your exported PDFs.' },
  { question: 'Do I need to sign up or create an account?', answer: 'No. There is no account, no email, and no trial period. Open a tool and use it immediately.' },
  { question: 'Are my files uploaded to a server?', answer: 'No. The tools run 100% locally in your browser, on desktop or mobile. Your PDF files are never sent over the network - they stay on your device the entire time.' },
  { question: 'Is PDkef open source?', answer: 'Yes. The entire codebase is open source under the MIT license, so you can inspect exactly what runs on your device.' },
];

// The tool list (home grid + hero card) comes from the shared registry, so it
// stays in sync with the tool pages and the sitemap. Ordered by SEO priority.
const HeroIcon = tools[0].icon;
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <SeoSchema name="PDkef" description={description} faq={faq} />
  </Fragment>

  <div class="first-fold-wrapper">
    <header class="hub-header">
    <div class="title-row">
      <img src="/favicon.png" width="42" height="42" aria-hidden="true" class="title-logo" alt="PDkef Logo" style="border-radius: 8px;" />
      <h1>Free PDF tools that run on your device</h1>
    </div>
    <p>Merge, sign, split, and compress PDFs without signing up, installing anything, or uploading a single file. Everything runs in your browser, on your phone or computer, so your files never leave your device.</p>
  </header>

  <main>
    {/* Hero Card for the first tool */}
    {tools.length > 0 && (
      <a href={tools[0].href} class="hero-card">
        <div class="hero-info">
          <span class="hero-badge">Local & Private</span>
          <h2>
            <HeroIcon size={24} strokeWidth={2.5} style="display: inline-block; vertical-align: text-bottom; margin-right: 0.5rem; color: var(--color-primary);" />
            {tools[0].gridTitle}
          </h2>
          <p>{tools[0].gridDescription}</p>
          <span class="hero-cta">
            Open tool
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </span>
        </div>
        <div class="hero-visual" aria-hidden="true">
          <div class="doc-mockup">
            <div class="doc-line short"></div>
            <div class="doc-line"></div>
            <div class="doc-line medium"></div>
            <div class="doc-sig-row">
              <div class="doc-sig-label">Sign here:</div>
              <div class="doc-sig-line">
                <svg class="cursive-signature" viewBox="0 0 100 30" fill="none" stroke="var(--color-primary)" stroke-width="2.2" stroke-linecap="round">
                  <path d="M10,20 Q25,5 35,22 T55,12 T75,25 T90,10" />
                </svg>
              </div>
            </div>
          </div>
          <div class="pen-mockup">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 20h9" />
              <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" />
            </svg>
          </div>
        </div>
      </a>
    )}

    {/* 4x2 Grid for the remaining 8 tools */}
    <div class="tool-grid">
      {tools.slice(1).map((tool) => (
        <a href={tool.href} class="tool-card">
          <div class="tool-icon">
            <tool.icon size={24} strokeWidth={2} />
          </div>
          <div class="tool-content">
            <h3>{tool.gridTitle}</h3>
            <p>{tool.gridDescription}</p>
          </div>
        </a>
      ))}
    </div>
  </main>
</div>

    <FeatureCard class="tool-content-card">
      <CardDecor sketch="arcs" icon={Sparkles} iconPos="tr" iconSize={300} />
      <div class="whypdkef-layout">
        <div class="whypdkef-copy">
          <span class="whypdkef-tag">Why I made this</span>
          <h2>The tools I wanted, shared with everyone</h2>
          <p>
            It started with a couple of ordinary errands. Someone close to me needed to combine a stack of course slides into one PDF before an exam, and to sign a summer-camp form that had arrived over WhatsApp. Simple things. But every tool we tried either capped the pages, wanted a subscription and a Windows install, or looked like the last place you would want to send a personal document.
          </p>
          <p>
            So I built the PDF tools I wanted for myself. Then I realised I wanted to share them. I believe simple, everyday tools like these should just be free and available to everyone, with no account, no paywall, and nothing uploaded to anyone's server.
          </p>
          <p class="whypdkef-detail">
            That is why PDkef runs entirely in your browser. There is no server to send your files to, which is what keeps it private and cheap enough to stay free for good. And it is open source, so you never have to take my word for any of it.
          </p>
          <p class="whypdkef-signature">
            <a href="https://shlomsh.github.io/readme/" target="_blank" rel="noopener noreferrer">Shlomi</a>
          </p>
        </div>
        <div class="whypdkef-proof">
          <div class="whypdkef-feat">
            <div class="whypdkef-feat-icon"><InfinityIcon size={20} strokeWidth={2} /></div>
            <div class="whypdkef-feat-text">
              <strong>Free Forever</strong>
              <span>No limits, no catch</span>
            </div>
          </div>
          <div class="whypdkef-feat">
            <div class="whypdkef-feat-icon"><Lock size={20} strokeWidth={2} /></div>
            <div class="whypdkef-feat-text">
              <strong>Private</strong>
              <span>Files never leave your device</span>
            </div>
          </div>
          <div class="whypdkef-feat">
            <div class="whypdkef-feat-icon"><Code2 size={20} strokeWidth={2} /></div>
            <div class="whypdkef-feat-text">
              <strong>Open Source</strong>
              <span>Audit the code yourself</span>
            </div>
          </div>
        </div>
      </div>
    </FeatureCard>

    <FeatureCard variant="highlight" class="tool-content-card">
      <CardDecor sketch="waves" icon={HardDriveDownload} iconPos="cr" iconSize={300} />
      <div class="autosave-layout">
        <div class="autosave-visual" aria-hidden="true">
          <div class="autosave-doc">
            <div class="doc-line short"></div>
            <div class="doc-line"></div>
            <div class="doc-line medium"></div>
            <div class="autosave-badge">
              <span class="pulse-dot"></span>
              Autosaved to device
            </div>
          </div>
        </div>
        <div class="autosave-content">
          <span class="autosave-tag">Privacy & Convenience</span>
          <h2>Work survives restarts and crashes</h2>
          <p>
            PDkef auto-saves your in-progress work locally to your browser's secure database. If you close the tab, restart your computer, or experience a crash, your PDF and edits are restored exactly where you left off.
          </p>
          <p class="autosave-subtext">
            Because it runs 100% on your device, we get "pick up where you left off" without sending a single byte of your file to a server. Available now in <strong>Sign & Fill</strong> and <strong>Redact & Blur</strong>.
          </p>
        </div>
      </div>
    </FeatureCard>

    <FeatureCard class="offline-section-custom tool-content-card">
      <CardDecor sketch="grid" icon={WifiOff} iconPos="br" iconSize={300} />
      <div class="offline-header">
        <h2>Run PDkef offline as an app</h2>
        <p>Because PDkef runs entirely in your web browser with zero server uploads, you can install it on your device and use it just like a native desktop or mobile application, even when you don't have internet access.</p>
      </div>

      <div class="offline-tabs-container">
        <div class="offline-tab-buttons" role="tablist" aria-label="Device installation guides">
          <button class="offline-tab-btn active" role="tab" aria-selected="true" aria-controls="guide-chrome" id="tab-chrome">
            <Monitor size={16} style="margin-right: 0.5rem;" />
            Chrome & Edge
          </button>
          <button class="offline-tab-btn" role="tab" aria-selected="false" aria-controls="guide-ios" id="tab-ios">
            <Smartphone size={16} style="margin-right: 0.5rem;" />
            Safari (iOS)
          </button>
          <button class="offline-tab-btn" role="tab" aria-selected="false" aria-controls="guide-safari" id="tab-safari">
            <Compass size={16} style="margin-right: 0.5rem;" />
            Safari (macOS)
          </button>
        </div>

        <div class="offline-tab-content">
          <div class="offline-tab-panel active" id="guide-chrome" role="tabpanel" aria-labelledby="tab-chrome">
            <ol class="step-list">
              <li>
                <span class="step-num">1</span>
                <span class="step-text">Navigate to the site in Chrome or Edge.</span>
              </li>
              <li>
                <span class="step-num">2</span>
                <span class="step-text">Click the <strong>Install</strong> icon (the screen with a down arrow) at the right of the address bar.</span>
              </li>
              <li>
                <span class="step-num">3</span>
                <span class="step-text">Alternatively, click the browser menu (three dots), select <strong>Save and share</strong>, and click <strong>Install PDkef</strong>.</span>
              </li>
            </ol>
          </div>

          <div class="offline-tab-panel" id="guide-ios" role="tabpanel" aria-labelledby="tab-ios" style="display: none;">
            <ol class="step-list">
              <li>
                <span class="step-num">1</span>
                <span class="step-text">Open the site in <strong>Safari</strong> on your iPhone or iPad.</span>
              </li>
              <li>
                <span class="step-num">2</span>
                <span class="step-text">Tap the <strong>Share</strong> button (square with an up arrow) in the toolbar.</span>
              </li>
              <li>
                <span class="step-num">3</span>
                <span class="step-text">Scroll down the options list and select <strong>Add to Home Screen</strong>.</span>
              </li>
            </ol>
          </div>

          <div class="offline-tab-panel" id="guide-safari" role="tabpanel" aria-labelledby="tab-safari" style="display: none;">
            <ol class="step-list">
              <li>
                <span class="step-num">1</span>
                <span class="step-text">Open the site in <strong>Safari</strong> on your Mac.</span>
              </li>
              <li>
                <span class="step-num">2</span>
                <span class="step-text">Click the <strong>Share</strong> button in the top-right Safari toolbar.</span>
              </li>
              <li>
                <span class="step-num">3</span>
                <span class="step-text">Select <strong>Add to Dock...</strong> from the dropdown menu and click <strong>Add</strong>.</span>
              </li>
            </ol>
          </div>
        </div>
      </div>
    </FeatureCard>

  <script>
    const tabs = document.querySelectorAll('.offline-tab-btn');
    const panels = document.querySelectorAll('.offline-tab-panel');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        // Deactivate current active tab & panel
        tabs.forEach(t => {
          t.classList.remove('active');
          t.setAttribute('aria-selected', 'false');
        });
        panels.forEach(p => {
          p.classList.remove('active');
          p.style.display = 'none';
        });

        // Activate clicked tab & panel
        tab.classList.add('active');
        tab.setAttribute('aria-selected', 'true');
        const panelId = tab.getAttribute('aria-controls');
        const targetPanel = document.getElementById(panelId);
        if (targetPanel) {
          targetPanel.classList.add('active');
          targetPanel.style.display = 'block';
        }
      });
    });
  </script>

  <FeatureCard class="tool-content-card">
    <CardDecor sketch="rings" icon={HelpCircle} iconPos="bl" iconSize={300} />
    <div class="faq-header">
      <span class="faq-tag">Got Questions?</span>
      <h2>Frequently asked questions</h2>
    </div>
    <div class="faq-grid">
      <div class="faq-card">
        <h3>Are the tools really free?</h3>
        <p>Yes, completely and permanently - no paywalls, no premium tier, no limits, and no watermark on your exported PDFs.</p>
      </div>
      <div class="faq-card">
        <h3>Do I need to sign up or create an account?</h3>
        <p>No. There is no account, no email, and no trial period. Open a tool and use it immediately.</p>
      </div>
      <div class="faq-card">
        <h3>Are my files uploaded to a server?</h3>
        <p>No. The tools run 100% locally in your browser, on desktop or mobile. Your PDF files are never sent over the network - they stay on your device the entire time.</p>
      </div>
      <div class="faq-card">
        <h3>Is PDkef open source?</h3>
        <p>Yes. The entire codebase is open source under the MIT license, so you can inspect exactly what runs on your device.</p>
      </div>
    </div>
  </FeatureCard>

  <FeatureCard variant="highlight" class="tool-content-card">
    <CardDecor sketch="arcs" icon={ShieldCheck} iconPos="cl" iconSize={300} />
    <div class="osp-content">
      <span class="osp-tag">Transparent & Secure</span>
      <h2>Open source & privacy</h2>
      <div class="osp-blocks">
        <div class="osp-block">
          <div class="osp-block-icon"><Lock size={22} strokeWidth={2} /></div>
          <h3>Privacy</h3>
          <p>Every tool runs 100% locally in your browser. Your files are never uploaded - PDkef has no server to send them to.</p>
        </div>
        <div class="osp-block">
          <div class="osp-block-icon"><Code2 size={22} strokeWidth={2} /></div>
          <h3>Open source</h3>
          <p>This project is open source under the MIT license. You can <a href="https://github.com/shlomsh/pdkef" target="_blank" rel="noopener noreferrer">view the source code on GitHub</a>. PDkef is built on other open source projects too - see the <a href="/licenses">open source licenses</a> page for the full list.</p>
          <span class="osp-badge">MIT Licensed</span>
        </div>
      </div>
    </div>
  </FeatureCard>

  <Footer />
</BaseLayout>

<style>
  .hub-header {
    padding: 3.5rem 1.5rem 2rem;
  }
  
  .title-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }
  
  .title-logo {
    flex-shrink: 0;
  }

  .hub-header h1 {
    margin-bottom: 0;
    text-align: left;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  /* Center the intro under the wordmark and cap it just short of the container
     width, so it lands on ~2 lines on wide desktops rather than stretching fully
     edge-to-edge. */
  .hub-header p {
    max-width: 54rem;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 3rem;
    padding: 2rem 2.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    margin-bottom: 2rem;
    box-shadow: var(--shadow-sm);
    position: relative;
    overflow: hidden;
    transition: transform 0.4s var(--ease-out), box-shadow 0.4s var(--ease-out), border-color 0.4s var(--ease-out);
  }

  .hero-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md), 0 12px 24px -8px var(--color-primary-ring);
    border-color: var(--color-primary-soft);
  }

  .hero-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.65rem;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.75rem;
    background: var(--color-primary-soft);
    color: var(--color-primary);
    border-radius: var(--radius-pill);
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .hero-info h2 {
    font-size: 1.75rem;
    font-weight: 800;
    margin: 0;
    color: var(--color-text);
    letter-spacing: -0.02em;
    display: flex;
    align-items: center;
  }

  .hero-info p {
    font-size: 0.95rem;
    line-height: 1.5;
    margin: 0;
    color: var(--color-muted);
    max-width: 560px;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-top: 0.25rem;
    transition: gap 0.2s var(--ease-out);
  }

  .hero-card:hover .hero-cta {
    gap: 0.75rem;
  }

  .hero-visual {
    position: relative;
    width: 200px;
    height: 120px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .doc-mockup {
    width: 150px;
    height: 105px;
    background: var(--color-surface);
    border: 1.5px solid var(--color-border-strong);
    border-radius: var(--radius-sm);
    padding: 1rem;
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    transition: border-color 0.3s var(--ease-out), transform 0.3s var(--ease-out);
  }

  .hero-card:hover .doc-mockup {
    border-color: var(--color-primary-soft);
    transform: scale(1.02);
  }

  .doc-line {
    height: 5px;
    background: var(--color-border-strong);
    border-radius: 3px;
    width: 100%;
  }

  .doc-line.short { width: 40%; }
  .doc-line.medium { width: 75%; }

  .doc-sig-row {
    margin-top: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .doc-sig-label {
    font-size: 0.65rem;
    color: var(--color-muted-light);
    font-weight: 500;
  }

  .doc-sig-line {
    flex: 1;
    border-bottom: 1px dashed var(--color-muted-light);
    height: 14px;
    position: relative;
  }

  .cursive-signature {
    position: absolute;
    bottom: -2px;
    left: 4px;
    width: 60px;
    height: 20px;
    color: var(--color-primary);
  }

  .pen-mockup {
    position: absolute;
    right: 15px;
    bottom: 5px;
    width: 28px;
    height: 28px;
    background: var(--color-surface);
    border: 1px solid var(--color-border-strong);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    box-shadow: var(--shadow-sm);
    transform: rotate(-15deg);
    transition: transform 0.3s var(--ease-spring), border-color 0.3s var(--ease-out);
  }

  .hero-card:hover .pen-mockup {
    transform: rotate(0deg) translate(-2px, -2px);
    border-color: var(--color-primary);
  }

  .pen-mockup svg {
    width: 14px;
    height: 14px;
  }

  .tool-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 1fr;
    gap: 1.5rem;
  }

  @media (max-width: 1024px) {
    .tool-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .hero-card {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
      padding: 1.5rem;
    }
    .hero-visual {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .tool-grid {
      grid-template-columns: 1fr;
    }
  }

  .tool-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    box-shadow: var(--shadow-sm);
    transition: transform 0.4s var(--ease-out), box-shadow 0.4s var(--ease-out), border-color 0.4s var(--ease-out);
    position: relative;
    overflow: hidden;
  }

  .tool-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, var(--color-primary-tint) 0%, transparent 70%);
    opacity: 0;
    transition: opacity 0.4s var(--ease-out);
    pointer-events: none;
    z-index: 0;
  }

  .tool-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md), 0 12px 24px -8px var(--color-primary-ring);
    border-color: var(--color-border-strong);
  }

  .tool-card:hover::before {
    opacity: 1;
  }

  .tool-icon, .tool-content {
    position: relative;
    z-index: 1;
  }

  .tool-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: var(--radius);
    background: #d4e2fc; /* A tone darker than primary-soft */
    color: var(--color-primary);
    margin-bottom: 1.25rem;
    transition: transform 0.2s var(--ease-spring), background-color 0.2s var(--ease-out);
  }

  .tool-card:hover .tool-icon {
    background: var(--color-primary);
    color: white;
    transform: scale(1.05);
  }

  .tool-content h3 {
    font-size: 1.15rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
    color: var(--color-text);
  }

  .tool-content p {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.5;
    color: var(--color-muted);
  }



  .whypdkef-tag {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }

  .whypdkef-copy h2 {
    font-size: 1.6rem;
    font-weight: 700;
    margin: 0 0 1rem;
    color: var(--color-text);
  }

  .whypdkef-copy p {
    font-size: 0.98rem;
    line-height: 1.6;
    color: var(--color-text);
    margin: 0 0 1rem;
    max-width: 800px;
  }

  .whypdkef-detail {
    font-size: 0.92rem;
    color: var(--color-muted);
  }

  .whypdkef-signature {
    font-size: 0.9rem;
    font-style: italic;
    color: var(--color-muted);
    margin-top: 1.25rem;
  }

  .whypdkef-signature a {
    font-style: normal;
    font-weight: 600;
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .whypdkef-signature a:hover {
    color: var(--color-primary-hover);
