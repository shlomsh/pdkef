---
import BaseLayout from '../layouts/BaseLayout.astro';
import SeoSchema from '../components/SeoSchema.astro';
import Footer from '../components/Footer.astro';
import FeatureCard from '../components/FeatureCard.astro';
import CardDecor from '../components/CardDecor.astro';
import AppBar from '../components/AppBar.astro';
import '../styles/global.css';

const title = 'Free PDF Tools - Private, Local, No Sign-Up | PDkef';
const description = 'A free, open-source suite of PDF tools that run entirely in your browser. Merge, sign, split, compress, and convert PDFs with nothing uploaded, no account, and no watermark. Your files never leave your device.';

import { Monitor, Smartphone, Compass, Sparkles, HardDriveDownload, WifiOff, HelpCircle, ShieldCheck, InfinityIcon, Lock, Code2 } from 'lucide-preact';
import { tools } from '../data/tools.js';
import FileDropzone from '../components/FileDropzone.jsx';

// FAQ schema mirrors the visible questions rendered in the footer below.
const faq = [
  { question: 'Are the tools really free?', answer: 'Yes, completely and permanently - no paywalls, no premium tier, no limits, and no watermark on your exported PDFs.' },
  { question: 'Do I need to sign up or create an account?', answer: 'No. There is no account, no email, and no trial period. Open a tool and use it immediately.' },
  { question: 'Are my files uploaded to a server?', answer: 'No. The tools run 100% locally in your browser, on desktop or mobile. Your PDF files are never sent over the network - they stay on your device the entire time.' },
  { question: 'Is PDkef open source?', answer: 'Yes. The entire codebase is open source under the MIT license, so you can inspect exactly what runs on your device.' },
];

// The tool list (home grid + hero card) comes from the shared registry, so it
// stays in sync with the tool pages and the sitemap. Ordered by SEO priority.
const HeroIcon = tools[0].icon;
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <SeoSchema name="PDkef" description={description} faq={faq} />
  </Fragment>

  <AppBar isHome />
  <div class="first-fold-wrapper">
    <header class="hub-header">
      <div class="title-row">
        <img src="/favicon.png" width="56" height="56" alt="" aria-hidden="true" class="title-logo" />
        <h1>Free PDF tools that run <span class="h1-accent">on your device</span></h1>
      </div>
      <p>Merge, sign, split, and compress PDFs without signing up, installing anything, or uploading a single file. Everything runs in your browser, on your phone or computer, so your files never leave your device.</p>
      
      <div class="mt-6 flex flex-wrap justify-center gap-[0.6rem]">
        <a class="inline-flex items-center gap-[0.45rem] rounded-[10px] border-[0.5px] border-[var(--color-border)] bg-[var(--color-surface)] px-[0.8rem] py-[0.45rem] text-[0.8rem] font-semibold text-[var(--color-text)] no-underline transition-[border-color,transform,color] duration-150 ease-[var(--ease-out)] hover:-translate-y-px hover:border-[var(--color-border-strong)] hover:text-[var(--color-text)]" href="https://github.com/shlomsh/pdkef" target="_blank" rel="noopener noreferrer">
          <svg class="shrink-0 text-[var(--color-text)]" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.85 9.73.5.1.68-.22.68-.49 0-.24-.01-.88-.01-1.72-2.79.62-3.38-1.37-3.38-1.37-.46-1.19-1.11-1.5-1.11-1.5-.91-.64.07-.62.07-.62 1 .07 1.53 1.06 1.53 1.06.89 1.56 2.34 1.11 2.91.85.09-.66.35-1.11.63-1.36-2.22-.26-4.56-1.14-4.56-5.07 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.71 0 0 .84-.28 2.75 1.05a9.34 9.34 0 0 1 5 0c1.91-1.33 2.75-1.05 2.75-1.05.55 1.41.2 2.45.1 2.71.64.72 1.03 1.63 1.03 2.75 0 3.94-2.34 4.81-4.57 5.06.36.32.68.94.68 1.9 0 1.37-.01 2.47-.01 2.81 0 .27.18.6.69.49A10.02 10.02 0 0 0 22 12.25C22 6.58 17.52 2 12 2z" />
          </svg>
          Star us on GitHub
          <svg class="shrink-0 text-[var(--color-primary)]" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2l2.9 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14l-5-4.87 7.1-1.01L12 2z" />
          </svg>
        </a>
        <span class="inline-flex items-center gap-[0.45rem] rounded-[10px] border-[0.5px] border-[var(--color-border)] bg-[var(--color-surface)] px-[0.8rem] py-[0.45rem] text-[0.8rem] font-semibold text-[var(--color-muted)]">
          <svg class="shrink-0 text-[var(--color-muted-light)]" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 3v18" /><path d="M7 7l-4 6a4 4 0 0 0 8 0l-4-6z" /><path d="M17 7l-4 6a4 4 0 0 0 8 0l-4-6z" /><path d="M6 21h12" /><path d="M8 5h8" />
          </svg>
          MIT licensed
        </span>
        <span class="inline-flex items-center gap-[0.45rem] rounded-[10px] border-[0.5px] border-[var(--color-border)] bg-[var(--color-surface)] px-[0.8rem] py-[0.45rem] text-[0.8rem] font-semibold text-[var(--color-muted)]">
          <svg class="shrink-0 text-[var(--color-muted-light)]" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 3l7 3v6c0 4.5-3 8-7 9-4-1-7-4.5-7-9V6l7-3z" /><path d="M9 12.5l2 2 4-4.5" />
          </svg>
          Runs in your browser
        </span>
      </div>
    </header>

  <main>
    {/* Large Dropzone CTA */}
    <div class="merge-tool merge-tool-cta">
      <FileDropzone client:load href="/sign?action=open" toolTarget="sign" />
    </div>

    {/* App Grid for all tools */}
    <div class="appgrid">
      {tools.map((tool) => (
        <a href={tool.href} class="app-card">
          <div class="app-tile">
            <tool.icon strokeWidth={1.5} />
          </div>
          <div class="app-lbl">{tool.gridTitle}</div>
          <span class="app-tooltip">{tool.gridDescription}</span>
        </a>
      ))}
    </div>
  </main>
</div>

    <FeatureCard class="relative isolate overflow-hidden">
      <CardDecor sketch="arcs" icon={Sparkles} iconPos="tr" iconSize={300} />
      <div class="flex items-stretch gap-12 max-[768px]:flex-col max-[768px]:gap-8">
        <div class="min-w-0 flex-[1.2]">
          <span class="mb-2 inline-block text-[0.72rem] font-bold uppercase tracking-normal text-[var(--color-primary)]">Why I made this</span>
          <h2 class="mb-4 mt-0 text-[1.6rem] font-bold tracking-normal text-[var(--color-text)]">The tools I wanted, shared with everyone</h2>
          <p class="mb-4 mt-0 max-w-[800px] text-[0.98rem] leading-[1.6] text-[var(--color-text)]">
            It started with a couple of ordinary errands. Someone close to me needed to combine a stack of course slides into one PDF before an exam, and to sign a summer-camp form that had arrived over WhatsApp. Simple things. But every tool we tried either capped the pages, wanted a subscription and a Windows install, or looked like the last place you would want to send a personal document.
          </p>
          <p class="mb-4 mt-0 max-w-[800px] text-[0.98rem] leading-[1.6] text-[var(--color-text)]">
            So I built the PDF tools I wanted for myself. Then I realised I wanted to share them. I believe simple, everyday tools like these should just be free and available to everyone, with no account, no paywall, and nothing uploaded to anyone's server.
          </p>
          <p class="mb-4 mt-0 max-w-[800px] text-[0.92rem] leading-[1.6] text-[var(--color-muted)]">
            That is why PDkef runs entirely in your browser. There is no server to send your files to, which is what keeps it private and cheap enough to stay free for good. And it is open source, so you never have to take my word for any of it.
          </p>
          <p class="mb-0 mt-5 text-[0.9rem] italic text-[var(--color-muted)]">
            <a class="font-semibold not-italic text-[var(--color-primary)] underline underline-offset-2 hover:text-[var(--color-primary-hover)]" href="https://shlomsh.github.io/readme/" target="_blank" rel="noopener noreferrer">Shlomi</a>
          </p>
        </div>
        <div class="flex flex-1 flex-col justify-center overflow-hidden rounded-[var(--radius)] border border-[var(--color-border)] bg-[var(--color-surface)] shadow-[var(--shadow-sm)]">
          <div class="group flex items-center gap-4 px-6 py-5 transition-colors duration-[250ms] ease-[var(--ease-out)] hover:bg-[var(--color-primary-tint)]">
            <div class="flex size-11 shrink-0 items-center justify-center rounded-[var(--radius-sm)] bg-[var(--color-primary-soft)] text-[var(--color-primary)] transition-[transform,background-color,color] duration-[250ms] ease-[var(--ease-out)] group-hover:scale-105 group-hover:bg-[var(--color-primary)] group-hover:text-[var(--color-surface)]"><InfinityIcon size={20} strokeWidth={2} /></div>
            <div class="flex min-w-0 flex-col gap-[0.2rem]">
              <strong class="text-[0.95rem] font-semibold text-[var(--color-text)]">Free Forever</strong>
              <span class="text-[0.85rem] text-[var(--color-muted)]">No limits, no catch</span>
            </div>
          </div>
          <div class="group flex items-center gap-4 border-t border-[var(--color-border)] px-6 py-5 transition-colors duration-[250ms] ease-[var(--ease-out)] hover:bg-[var(--color-primary-tint)]">
            <div class="flex size-11 shrink-0 items-center justify-center rounded-[var(--radius-sm)] bg-[var(--color-primary-soft)] text-[var(--color-primary)] transition-[transform,background-color,color] duration-[250ms] ease-[var(--ease-out)] group-hover:scale-105 group-hover:bg-[var(--color-primary)] group-hover:text-[var(--color-surface)]"><Lock size={20} strokeWidth={2} /></div>
            <div class="flex min-w-0 flex-col gap-[0.2rem]">
              <strong class="text-[0.95rem] font-semibold text-[var(--color-text)]">Private</strong>
              <span class="text-[0.85rem] text-[var(--color-muted)]">Files never leave your device</span>
            </div>
          </div>
          <div class="group flex items-center gap-4 border-t border-[var(--color-border)] px-6 py-5 transition-colors duration-[250ms] ease-[var(--ease-out)] hover:bg-[var(--color-primary-tint)]">
            <div class="flex size-11 shrink-0 items-center justify-center rounded-[var(--radius-sm)] bg-[var(--color-primary-soft)] text-[var(--color-primary)] transition-[transform,background-color,color] duration-[250ms] ease-[var(--ease-out)] group-hover:scale-105 group-hover:bg-[var(--color-primary)] group-hover:text-[var(--color-surface)]"><Code2 size={20} strokeWidth={2} /></div>
            <div class="flex min-w-0 flex-col gap-[0.2rem]">
              <strong class="text-[0.95rem] font-semibold text-[var(--color-text)]">Open Source</strong>
              <span class="text-[0.85rem] text-[var(--color-muted)]">Audit the code yourself</span>
            </div>
          </div>
        </div>
      </div>
    </FeatureCard>

    <FeatureCard variant="highlight" class="relative isolate overflow-hidden">
      <CardDecor sketch="waves" icon={HardDriveDownload} iconPos="cr" iconSize={300} />
      <div class="flex items-center gap-12 max-[768px]:flex-col-reverse max-[768px]:gap-8">
        <div class="relative flex min-h-[150px] w-full flex-[0.8] items-center justify-center" aria-hidden="true">
          <div class="relative flex h-[120px] w-[160px] flex-col gap-2 rounded-[var(--radius-sm)] border-[1.5px] border-[var(--color-primary-soft)] bg-[var(--color-surface)] px-4 py-5 shadow-[var(--shadow-sm)]">
            <div class="doc-line short"></div>
            <div class="doc-line"></div>
            <div class="doc-line medium"></div>
            <div class="absolute -bottom-2.5 -right-2.5 inline-flex items-center gap-[0.35rem] rounded-[var(--radius-pill)] border border-[color-mix(in_srgb,var(--color-success)_20%,transparent)] bg-[var(--color-success-soft)] px-[0.6rem] py-[0.3rem] text-[0.7rem] font-semibold text-[var(--color-success)] shadow-[var(--shadow-sm)]">
              <span class="size-1.5 rounded-full bg-[var(--color-success)] animate-[pulse_2s_infinite]"></span>
              Autosaved to device
            </div>
          </div>
        </div>
        <div class="flex-[1.2]">
          <span class="mb-2 inline-block text-[0.72rem] font-bold uppercase tracking-normal text-[var(--color-primary)]">Privacy & Convenience</span>
          <h2 class="mb-4 mt-0 text-[1.6rem] font-bold tracking-normal text-[var(--color-text)]">Work survives restarts and crashes</h2>
          <p class="mb-4 mt-0 text-[0.98rem] leading-[1.6] text-[var(--color-text)]">
            PDkef auto-saves your in-progress work locally to your browser's secure database. If you close the tab, restart your computer, or experience a crash, your PDF and edits are restored exactly where you left off.
          </p>
          <p class="mb-0 mt-0 text-[0.9rem] leading-[1.6] text-[var(--color-muted)]">
            Because it runs 100% on your device, we get "pick up where you left off" without sending a single byte of your file to a server. Available now in <strong>Sign & Fill</strong> and <strong>Redact & Blur</strong>.
          </p>
        </div>
      </div>
    </FeatureCard>

    <FeatureCard class="offline-section-custom relative isolate overflow-hidden">
      <CardDecor sketch="grid" icon={WifiOff} iconPos="br" iconSize={300} />
      <div class="offline-header">
        <h2>Run PDkef offline as an app</h2>
        <p>Because PDkef runs entirely in your web browser with zero server uploads, you can install it on your device and use it just like a native desktop or mobile application, even when you don't have internet access.</p>
      </div>

      <div class="offline-tabs-container">
        <div class="offline-tab-buttons" role="tablist" aria-label="Device installation guides">
          <button class="offline-tab-btn active" role="tab" aria-selected="true" aria-controls="guide-chrome" id="tab-chrome">
            <Monitor size={16} class="tab-btn-icon" />
            Chrome & Edge
          </button>
          <button class="offline-tab-btn" role="tab" aria-selected="false" aria-controls="guide-ios" id="tab-ios">
            <Smartphone size={16} class="tab-btn-icon" />
            Safari (iOS)
          </button>
          <button class="offline-tab-btn" role="tab" aria-selected="false" aria-controls="guide-safari" id="tab-safari">
            <Compass size={16} class="tab-btn-icon" />
            Safari (macOS)
          </button>
        </div>

        <div class="offline-tab-content">
          <div class="offline-tab-panel active" id="guide-chrome" role="tabpanel" aria-labelledby="tab-chrome">
            <ol class="step-list">
              <li>
                <span class="step-num">1</span>
                <span class="step-text">Navigate to the site in Chrome or Edge.</span>
              </li>
              <li>
                <span class="step-num">2</span>
                <span class="step-text">Click the <strong>Install</strong> icon (the screen with a down arrow) at the right of the address bar.</span>
              </li>
              <li>
                <span class="step-num">3</span>
                <span class="step-text">Alternatively, click the browser menu (three dots), select <strong>Save and share</strong>, and click <strong>Install PDkef</strong>.</span>
              </li>
            </ol>
          </div>

          <div class="offline-tab-panel" id="guide-ios" role="tabpanel" aria-labelledby="tab-ios">
            <ol class="step-list">
              <li>
                <span class="step-num">1</span>
                <span class="step-text">Open the site in <strong>Safari</strong> on your iPhone or iPad.</span>
              </li>
              <li>
                <span class="step-num">2</span>
                <span class="step-text">Tap the <strong>Share</strong> button (square with an up arrow) in the toolbar.</span>
              </li>
              <li>
                <span class="step-num">3</span>
                <span class="step-text">Scroll down the options list and select <strong>Add to Home Screen</strong>.</span>
              </li>
            </ol>
          </div>

          <div class="offline-tab-panel" id="guide-safari" role="tabpanel" aria-labelledby="tab-safari">
            <ol class="step-list">
              <li>
                <span class="step-num">1</span>
                <span class="step-text">Open the site in <strong>Safari</strong> on your Mac.</span>
              </li>
              <li>
                <span class="step-num">2</span>
                <span class="step-text">Click the <strong>Share</strong> button in the top-right Safari toolbar.</span>
              </li>
              <li>
                <span class="step-num">3</span>
                <span class="step-text">Select <strong>Add to Dock...</strong> from the dropdown menu and click <strong>Add</strong>.</span>
              </li>
            </ol>
          </div>
        </div>
      </div>
    </FeatureCard>

  <script>
    const tabs = document.querySelectorAll('.offline-tab-btn');
    const panels = document.querySelectorAll('.offline-tab-panel');

    tabs.forEach(tab => {
      tab.addEventListener('click', () => {
        // Deactivate current active tab & panel
        tabs.forEach(t => {
          t.classList.remove('active');
          t.setAttribute('aria-selected', 'false');
        });
        panels.forEach(p => p.classList.remove('active'));

        // Activate clicked tab & panel (visibility is handled by CSS on .active)
        tab.classList.add('active');
        tab.setAttribute('aria-selected', 'true');
        const panelId = tab.getAttribute('aria-controls');
        const targetPanel = document.getElementById(panelId);
        if (targetPanel) {
          targetPanel.classList.add('active');
        }
      });
    });
  </script>

  <FeatureCard class="relative isolate overflow-hidden">
    <CardDecor sketch="rings" icon={HelpCircle} iconPos="bl" iconSize={300} />
    <div class="mb-12 text-center">
      <span class="mb-2 inline-block text-[0.72rem] font-bold uppercase tracking-normal text-[var(--color-primary)]">Got Questions?</span>
      <h2 class="m-0 text-[1.6rem] font-bold tracking-normal text-[var(--color-text)]">Frequently asked questions</h2>
    </div>
    <div class="grid grid-cols-2 gap-x-12 gap-y-8 max-[768px]:grid-cols-1 max-[768px]:gap-6">
      <div class="faq-card">
        <h3 class="mb-2 mt-0 text-[1.05rem] font-semibold tracking-normal text-[var(--color-text)]">Are the tools really free?</h3>
        <p class="m-0 text-[0.95rem] leading-[1.5] text-[var(--color-muted)]">Yes, completely and permanently - no paywalls, no premium tier, no limits, and no watermark on your exported PDFs.</p>
      </div>
      <div class="faq-card">
        <h3 class="mb-2 mt-0 text-[1.05rem] font-semibold tracking-normal text-[var(--color-text)]">Do I need to sign up or create an account?</h3>
        <p class="m-0 text-[0.95rem] leading-[1.5] text-[var(--color-muted)]">No. There is no account, no email, and no trial period. Open a tool and use it immediately.</p>
      </div>
      <div class="faq-card">
        <h3 class="mb-2 mt-0 text-[1.05rem] font-semibold tracking-normal text-[var(--color-text)]">Are my files uploaded to a server?</h3>
        <p class="m-0 text-[0.95rem] leading-[1.5] text-[var(--color-muted)]">No. The tools run 100% locally in your browser, on desktop or mobile. Your PDF files are never sent over the network - they stay on your device the entire time.</p>
      </div>
      <div class="faq-card">
        <h3 class="mb-2 mt-0 text-[1.05rem] font-semibold tracking-normal text-[var(--color-text)]">Is PDkef open source?</h3>
        <p class="m-0 text-[0.95rem] leading-[1.5] text-[var(--color-muted)]">Yes. The entire codebase is open source under the MIT license, so you can inspect exactly what runs on your device.</p>
      </div>
    </div>
  </FeatureCard>

  <FeatureCard variant="highlight" class="relative isolate overflow-hidden">
    <CardDecor sketch="arcs" icon={ShieldCheck} iconPos="cl" iconSize={300} />
    <div class="osp-content">
      <span class="osp-tag">Transparent & Secure</span>
      <h2>Open source & privacy</h2>
      <div class="osp-blocks">
        <div class="osp-block">
          <div class="osp-block-icon"><Lock size={22} strokeWidth={2} /></div>
          <h3>Privacy</h3>
          <p>Every tool runs 100% locally in your browser. Your files are never uploaded - PDkef has no server to send them to.</p>
        </div>
        <div class="osp-block">
          <div class="osp-block-icon"><Code2 size={22} strokeWidth={2} /></div>
          <h3>Open source</h3>
          <p>This project is open source under the MIT license. You can <a href="https://github.com/shlomsh/pdkef" target="_blank" rel="noopener noreferrer">view the source code on GitHub</a>. PDkef is built on other open source projects too - see the <a href="/licenses">open source licenses</a> page for the full list.</p>
          <span class="osp-badge">MIT Licensed</span>
        </div>
      </div>
    </div>
  </FeatureCard>

  <Footer />
</BaseLayout>

<style>
  /* These were inline style="" attributes; moved to scoped classes so a strict
     CSP style-src (no unsafe-inline) does not block them at parse time. */
  .h1-accent {
    color: var(--color-primary);
  }

  .merge-tool-cta {
    max-width: 1032px;
    margin: 0 auto 4rem auto;
    padding: 1.5rem;
    box-sizing: border-box;
  }

  .tab-btn-icon {
    margin-right: 0.5rem;
  }

  .hub-header {
    padding: 3.5rem 1.5rem 2rem;
  }
  
  .title-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }
  
  .title-logo {
    flex-shrink: 0;
  }

  .hub-header h1 {
    margin-bottom: 0;
    text-align: left;
    line-height: 1.1;
    letter-spacing: -0.02em;
  }

  /* Center the intro under the wordmark and cap it just short of the container
     width, so it lands on ~2 lines on wide desktops rather than stretching fully
     edge-to-edge. */
  .hub-header p {
    max-width: 54rem;
    margin-left: auto;
    margin-right: auto;
  }

  .hero-chips {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }
  
  .hero-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.45rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-pill);
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--color-muted);
    text-decoration: none;
    box-shadow: var(--shadow-xs);
    transition: transform 0.2s var(--ease-out), box-shadow 0.2s var(--ease-out), border-color 0.2s var(--ease-out), color 0.2s var(--ease-out);
  }
  
  .hero-chip:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-sm);
    border-color: var(--color-border-strong);
    color: var(--color-text);
  }

  .appgrid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 24px;
    max-width: 1080px;
    margin: 0 auto 3rem;
    padding: 1.5rem 1.5rem 1.5rem;
  }

  .app-card {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    width: 80px;
    flex-shrink: 0;
    cursor: pointer;
    text-decoration: none;
    color: inherit;
    outline: none;
  }

  .app-tile {
    width: 64px;
    height: 64px;
    border-radius: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
