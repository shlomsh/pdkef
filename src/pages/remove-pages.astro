---
import BaseLayout from '../layouts/BaseLayout.astro';
import SeoSchema from '../components/SeoSchema.astro';
import PdfRemovePagesTool from '../components/PdfRemovePagesTool.jsx';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const title = 'Remove Pages from PDF Online Free - Delete PDF Pages';
const description =
  'Delete unwanted pages from your PDF document online for free. Visual page grid selection, fast and 100% private in-browser processing. No upload required.';

// Structured data mirrors the visible HowTo + FAQ rendered below.
const howTo = {
  name: 'How to remove pages from a PDF online for free',
  steps: [
    { name: 'Add your PDF file', text: 'Select or drag-and-drop the PDF file from your device.' },
    { name: 'Select pages to delete', text: 'Click on the page thumbnails in the grid to mark them for removal. Unwanted pages will be dimmed.' },
    { name: 'Apply changes and download', text: 'Click the Remove Pages button to process and download your updated PDF file.' },
  ],
};

const faq = [
  {
    question: 'Are my PDF files uploaded to your servers?',
    answer: 'No. PDkef is a 100% client-side tool. All PDF parsing and page deletion happen directly in your browser on your device. Your file contents never leave your computer or phone.',
  },
  {
    question: 'How do I select pages to remove?',
    answer: 'Once you select a PDF, all its pages will render as a thumbnail grid. Simply click any page thumbnail to mark it for removal. Click it again if you change your mind and want to keep it.',
  },
  {
    question: 'Can I remove all pages from a PDF?',
    answer: 'No. A valid PDF file must contain at least one page. The tool will disable the action button if you select all pages for deletion.',
  },
  {
    question: 'Is there a file size limit?',
    answer: 'There are no artificial file size limits on PDkef. The only constraint is your device’s memory, since all processing runs locally in your browser.',
  },
];
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <SeoSchema name="PDkef - Remove PDF Pages" description={description} howTo={howTo} faq={faq} />
  </Fragment>

  <header>
    <h1>Remove pages from PDF</h1>
    <p>Select and delete unwanted pages from your document instantly, completely offline.</p>
  </header>

  <main>
    <section id="app" aria-label="Remove PDF pages tool">
      <PdfRemovePagesTool client:load />
    </section>
  </main>

  <Footer summaryText="Delete unwanted pages from your PDF documents directly in your browser. No uploads, no servers, absolute privacy.">
    <section id="how-it-works">
      <h2>How to remove pages from a PDF online for free</h2>
      <ol>
        <li><strong>Add your PDF.</strong> Select or drag-and-drop the file you want to edit.</li>
        <li><strong>Select pages to delete.</strong> Click on the page thumbnails to mark them for removal.</li>
        <li><strong>Apply and download.</strong> Click the Remove Pages button to process and save your new PDF.</li>
      </ol>
    </section>

    <section id="why-pdkef">
      <h2>Why use PDkef to delete PDF pages</h2>
      <ul>
        <li><strong>Free:</strong> No fees, no limits, no signup, and no watermarks.</li>
        <li><strong>No server, no paywalls:</strong> most online PDF tools cap free use or hide features behind a paywall because every file costs them server time. This one runs 100% locally on your device, so there's nothing to ration.</li>
        <li><strong>Private:</strong> Your files stay on your device; they are never uploaded.</li>
        <li><strong>Fast:</strong> Deleting pages takes seconds because it is processed locally.</li>
        <li><strong>Easy-to-use:</strong> Interactive visual grid makes selecting pages intuitive.</li>
        <li><strong>Open source:</strong> Built with safe, standard libraries under the MIT license.</li>
      </ul>
    </section>

    <section id="faq">
      <h2>Frequently asked questions</h2>
      <h3>Are my PDF files uploaded to your servers?</h3>
      <p>No. PDkef is a 100% client-side tool. All PDF parsing and page deletion happen directly in your browser on your device. Your file contents never leave your computer or phone.</p>
      <h3>How do I select pages to remove?</h3>
      <p>Once you select a PDF, all its pages will render as a thumbnail grid. Simply click any page thumbnail to mark it for removal. Click it again if you change your mind and want to keep it.</p>
      <h3>Can I remove all pages from a PDF?</h3>
      <p>No. A valid PDF file must contain at least one page. The tool will disable the action button if you select all pages for deletion.</p>
      <h3>Is there a file size limit?</h3>
      <p>There are no artificial file size limits on PDkef. The only constraint is your device’s memory, since all processing runs locally in your browser.</p>
    </section>
  </Footer>
</BaseLayout>
