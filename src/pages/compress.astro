---
import BaseLayout from '../layouts/BaseLayout.astro';
import SeoSchema from '../components/SeoSchema.astro';
import PdfCompressTool from '../components/PdfCompressTool.jsx';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const title = 'Compress PDF Online Free - Reduce PDF File Size | PDkef';
const description =
  'Compress PDF files online for free. Reduce the file size of your documents without losing quality. 100% private, runs in your browser.';

const howTo = {
  name: 'How to compress PDF files online for free',
  steps: [
    { name: 'Upload your PDF', text: 'Select or drag-and-drop the PDF file you want to compress.' },
    { name: 'Choose compression level', text: 'Select Extreme, Recommended, or High Quality compression option based on your needs.' },
    { name: 'Compress and download', text: 'Click Compress PDF, view your size savings, and download the optimized PDF.' },
  ],
};

const faq = [
  { question: 'Is the PDF compression secure?', answer: 'Yes. The compression is 100% client-side and runs entirely in your browser. Your files are never uploaded to any server, keeping your data private.' },
  { question: 'What is the difference between the compression levels?', answer: 'Extreme compression reduces file size by 60-80% using 72 DPI images. Recommended compression reduces size by 40-60% at 110 DPI. High Quality compression reduces size by 10-30% at 150 DPI.' },
  { question: 'Can I compress a PDF to a specific size, like 100KB?', answer: 'Extreme compression (72 DPI) gets most scanned documents and form PDFs under the common 100KB-1MB limits used by government, academic, and job application portals. Try Extreme first, then step up to Recommended if the result looks too soft.' },
  { question: 'Does compressing a PDF affect text search or copying?', answer: 'Yes. To compress the document client-side safely, pages are rasterized into images. This means text selection, copy-pasting, and embedded links will be disabled in the output file.' },
  { question: 'Is there a limit on the file size I can compress?', answer: "There is no artificial file size limit, no daily task cap, and no watermark - the limits most free online compressors impose to ration server costs. Compression runs entirely on your device, so the only limitation is your device's system memory (RAM)." },
];
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <SeoSchema name="PDkef - Compress PDF" description={description} howTo={howTo} faq={faq} />
  </Fragment>

  <header>
    <h1>Compress PDF online, free</h1>
    <p>Reduce the size of your PDF files instantly. Secure, client-side compression.</p>
  </header>

  <main>
    <section id="app" aria-label="PDF compress tool">
      <PdfCompressTool client:load />
    </section>
  </main>
  
  <Footer summaryText="Reduce the file size of your PDFs, right in your browser. No upload, no server. Your files never leave your device.">
    <section id="how-it-works">
      <h2>How to compress PDF files online for free</h2>
      <ol>
        <li><strong>Upload your PDF.</strong> Select or drag-and-drop the file you want to compress.</li>
        <li><strong>Choose compression level.</strong> Select Extreme, Recommended, or High Quality compression depending on your size and resolution needs.</li>
        <li><strong>Compress and download.</strong> Click Compress PDF, review the file size savings, and save your compressed document.</li>
      </ol>
    </section>

    <section id="why-pdkef">
      <h2>Why use PDkef</h2>
      <ul>
        <li><strong>Free:</strong> no cost, no signup, no watermark, no limits.</li>
        <li><strong>No server, no paywalls:</strong> most online compressors cap free use or hide features behind a paywall because every file costs them server time. This one runs 100% locally on your device, so there's nothing to ration.</li>
        <li><strong>Private:</strong> your files never leave your device; nothing is uploaded.</li>
        <li><strong>Fast:</strong> compression happens instantly in your browser.</li>
        <li><strong>Works everywhere:</strong> Chrome on macOS, Windows, Android, and iOS.</li>
        <li><strong>Open source:</strong> the entire codebase is public and MIT licensed - inspect exactly what runs on your device.</li>
      </ul>
    </section>

    <section id="faq">
      <h2>Frequently asked questions</h2>
      <h3>Is the PDF compression secure?</h3>
      <p>Yes. The compression is 100% client-side and runs entirely in your browser. Your files are never uploaded to any server, keeping your data private.</p>
      <h3>What is the difference between the compression levels?</h3>
      <p>Extreme compression reduces file size by 60-80% using 72 DPI images. Recommended compression reduces size by 40-60% at 110 DPI. High Quality compression reduces size by 10-30% at 150 DPI.</p>
      <h3>Can I compress a PDF to a specific size, like 100KB?</h3>
      <p>Extreme compression (72 DPI) gets most scanned documents and form PDFs under the common 100KB-1MB limits used by government, academic, and job application portals. Try Extreme first, then step up to Recommended if the result looks too soft.</p>
      <h3>Does compressing a PDF affect text search or copying?</h3>
      <p>Yes. To compress the document client-side safely, pages are rasterized into images. This means text selection, copy-pasting, and embedded links will be disabled in the output file.</p>
      <h3>Is there a limit on the file size I can compress?</h3>
      <p>There is no artificial file size limit, no daily task cap, and no watermark - the limits most free online compressors impose to ration server costs. Compression runs entirely on your device, so the only limitation is your device's system memory (RAM).</p>
    </section>
  </Footer>
</BaseLayout>
